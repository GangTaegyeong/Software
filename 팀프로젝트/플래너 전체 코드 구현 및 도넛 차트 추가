<!DOCTYPE html>
<html lang="ko" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Adaptive Study Planner</title>
  
  <style>
    :root {
      --bg: #f8fafc;
      --surface: #ffffff;
      --surface-soft: #f9fafb;
      --line: #e5e7eb;
      --line-strong: #d1d5db;
      --text: #111827;
      --muted: #6b7280;
      --muted-soft: #9ca3af;
      --primary: #4f46e5;
      --primary-soft: #f1f2ff;
      --danger: #dc6868;
      --danger-soft: #fff5f5;
      --warning: #b7791f;
      --warning-soft: #fffaf0;
      --success: #2f855a;
      --success-soft: #f0fff4;
      --shadow: 0 8px 24px rgba(15, 23, 42, 0.045);
      --shadow-hover: 0 12px 28px rgba(15, 23, 42, 0.07);
      --radius-xl: 22px;
      --radius-lg: 18px;
      --radius-md: 12px;
    }

    html[data-theme="dark"] {
      --bg: #0f172a;
      --surface: #111827;
      --surface-soft: #162033;
      --line: #263349;
      --line-strong: #3b4a64;
      --text: #f8fafc;
      --muted: #a5b4c7;
      --muted-soft: #8190a6;
      --primary: #a5b4fc;
      --primary-soft: rgba(165, 180, 252, 0.12);
      --danger: #fca5a5;
      --danger-soft: rgba(252, 165, 165, 0.10);
      --warning: #facc15;
      --warning-soft: rgba(250, 204, 21, 0.10);
      --success: #86efac;
      --success-soft: rgba(134, 239, 172, 0.10);
      --shadow: 0 12px 30px rgba(0, 0, 0, 0.20);
      --shadow-hover: 0 16px 34px rgba(0, 0, 0, 0.28);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      -webkit-font-smoothing: antialiased;
      text-rendering: geometricPrecision;
      font-family: Inter, ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans KR", "Apple SD Gothic Neo", Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    button, input, select { font: inherit; }
    button { cursor: pointer; }

    .page {
      max-width: 1220px;
      margin: 0 auto;
      padding: 28px 20px 44px;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow);
    }

    .hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 320px;
      align-items: start;
      gap: 22px;
      margin-bottom: 18px;
      padding: 30px;
      background: var(--surface);
    }

    .app-title {
      margin: 0;
      color: var(--primary);
      font-size: clamp(34px, 5vw, 54px);
      line-height: 1.02;
      letter-spacing: -0.035em;
      font-weight: 850;
    }

    .subtitle {
      margin: 14px 0 0;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.65;
      max-width: 760px;
    }

    .top-controls {
      display: grid;
      gap: 10px;
      min-width: 0;
    }

    .mode-controls {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    .day-nav {
      display: grid;
      grid-template-columns: auto minmax(150px, 1fr) auto;
      align-items: center;
      gap: 7px;
      padding: 7px;
      border-radius: 16px;
      background: var(--surface-soft);
      border: 1px solid var(--line);
    }

    .day-btn,
    .icon-btn,
    .pill-btn,
    .primary-btn,
    .ghost-btn,
    .toggle-btn,
    .today-nav-btn {
      border: 1px solid var(--line);
      border-radius: 11px;
      background: var(--surface);
      color: var(--text);
      font-weight: 750;
      transition: background 0.14s ease, color 0.14s ease, border-color 0.14s ease, transform 0.14s ease, box-shadow 0.14s ease;
    }

    .day-btn:hover,
    .icon-btn:hover,
    .pill-btn:hover,
    .ghost-btn:hover,
    .toggle-btn:hover {
      border-color: var(--line-strong);
      background: var(--surface-soft);
      transform: translateY(-1px);
    }

    .day-btn { padding: 9px 11px; font-size: 12px; white-space: nowrap; }
    .toggle-btn { padding: 10px 12px; font-size: 12px; }

    .selected-date {
      text-align: center;
      color: var(--text);
      font-size: 13px;
      font-weight: 800;
      white-space: nowrap;
      padding: 0 4px;
    }

    .today-nav-btn {
      grid-column: 1 / -1;
      width: 100%;
      padding: 9px 12px;
      background: var(--primary-soft);
      color: var(--primary);
      border-color: transparent;
      font-size: 12px;
    }

    .summary-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
      margin-bottom: 16px;
    }

    .metric-card { padding: 17px; min-height: 112px; }

    .metric-label {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 750;
    }

    .metric-value {
      margin-top: 11px;
      font-size: 28px;
      font-weight: 850;
      letter-spacing: -0.045em;
    }

    .metric-help { margin-top: 8px; color: var(--muted); font-size: 12px; line-height: 1.48; }

    .dot { width: 8px; height: 8px; border-radius: 999px; background: var(--primary); box-shadow: 0 0 0 4px var(--primary-soft); }
    .dot.success { background: var(--success); box-shadow: 0 0 0 4px var(--success-soft); }
    .dot.warning { background: var(--warning); box-shadow: 0 0 0 4px var(--warning-soft); }
    .dot.danger { background: var(--danger); box-shadow: 0 0 0 4px var(--danger-soft); }

    .calendar-card { padding: 20px; margin-bottom: 18px; }

    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      margin-bottom: 15px;
    }

    .section-title { margin: 0; font-size: 20px; letter-spacing: -0.035em; font-weight: 820; }
    .section-caption { margin: 5px 0 0; color: var(--muted); font-size: 12.5px; line-height: 1.45; }

    .calendar-nav { display: flex; align-items: center; gap: 8px; }
    .icon-btn { width: 34px; height: 34px; display: grid; place-items: center; font-size: 17px; }
    .month-label { min-width: 138px; text-align: center; font-size: 14px; font-weight: 820; }

    .selected-day-summary {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 8px;
      margin: -2px 0 15px;
      padding: 11px 13px;
      border-radius: 14px;
      background: var(--surface-soft);
      border: 1px solid var(--line);
      color: var(--muted);
      font-size: 12.5px;
      line-height: 1.45;
    }
    .selected-day-summary strong { color: var(--text); font-size: 13px; }

    .calendar-weekdays,
    .calendar-grid { display: grid; grid-template-columns: repeat(7, minmax(0, 1fr)); gap: 8px; }
    .calendar-weekdays { margin-bottom: 8px; }
    .weekday { text-align: center; color: var(--muted-soft); font-size: 11px; font-weight: 760; padding: 5px 0; }

    .day-cell {
      min-height: 112px;
      padding: 10px;
      border-radius: 15px;
      border: 1px solid var(--line);
      background: var(--surface);
      display: flex;
      flex-direction: column;
      gap: 7px;
      text-align: left;
      color: var(--text);
      width: 100%;
      box-shadow: none;
    }
    .day-cell:hover { border-color: var(--line-strong); background: var(--surface-soft); transform: translateY(-1px); }
    .day-cell.muted { opacity: 0.42; background: var(--surface-soft); }
    .day-cell.today { border-color: rgba(79, 70, 229, 0.35); box-shadow: inset 0 0 0 1px rgba(79, 70, 229, 0.16); }
    .day-cell.selected { border-color: var(--primary); box-shadow: inset 0 0 0 2px rgba(79, 70, 229, 0.20); }

    .day-number { display: flex; align-items: center; justify-content: space-between; gap: 6px; font-size: 13px; font-weight: 830; }
    .today-chip { padding: 3px 7px; border-radius: 999px; background: var(--primary-soft); color: var(--primary); font-size: 10px; font-weight: 850; }

    .badge-stack { display: grid; gap: 5px; margin-top: auto; }
    .mini-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      width: fit-content;
      max-width: 100%;
      padding: 4px 7px;
      border-radius: 999px;
      font-size: 10.5px;
      font-weight: 750;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      border: 1px solid transparent;
    }
    .mini-badge.primary { background: var(--primary-soft); color: var(--primary); }
    .mini-badge.success { background: var(--success-soft); color: var(--success); }
    .mini-badge.warning { background: var(--warning-soft); color: var(--warning); }
    .mini-badge.danger { background: var(--danger-soft); color: var(--danger); }
    .mini-badge.gray { background: var(--surface-soft); color: var(--muted); border-color: var(--line); }

    .content-grid {
      display: grid;
      grid-template-columns: 230px minmax(0, 1.42fr) 300px;
      gap: 16px;
      align-items: start;
    }

    .panel { padding: 18px; }
    .subject-panel { position: sticky; top: 18px; max-height: calc(100vh - 36px); overflow: auto; }
    .subject-board { display: grid; gap: 9px; }

    .subject-card,
    .priority-card,
    .task-row,
    .focus-block {
      border: 1px solid var(--line);
      color: var(--text);
      box-shadow: none;
    }

    .subject-card {
      width: 100%;
      border-radius: 15px;
      padding: 13px;
      text-align: left;
      transition: border-color 0.14s ease, transform 0.14s ease, box-shadow 0.14s ease;
    }
    .subject-card:hover { border-color: var(--line-strong); transform: translateY(-1px); box-shadow: var(--shadow); }
    .subject-card.active { border-color: var(--primary); box-shadow: inset 0 0 0 1px rgba(79, 70, 229, 0.16); }

    .subject-head { display: flex; justify-content: space-between; align-items: center; gap: 10px; margin-bottom: 7px; }
    .subject-name { font-size: 13.5px; font-weight: 830; letter-spacing: -0.02em; }
    .subject-count { padding: 4px 8px; border-radius: 999px; background: rgba(255,255,255,0.72); color: var(--text); font-size: 10.5px; font-weight: 800; white-space: nowrap; border: 1px solid rgba(17,24,39,0.04); }
    html[data-theme="dark"] .subject-count { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.08); }
    .subject-stat { color: var(--muted); font-size: 11.5px; line-height: 1.45; margin-bottom: 8px; }
    .subject-preview { display: grid; gap: 4px; }
    .subject-preview-item { display: block; color: var(--muted); font-size: 11.5px; line-height: 1.35; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    .priority-reason { margin: 7px 0 9px; color: var(--muted); font-size: 11.5px; line-height: 1.5; }
    .rank-label { display: inline-flex; align-items: center; gap: 7px; margin-bottom: 10px; }
    .rank-label .rank { margin-bottom: 0; }
    .rank-text { color: var(--muted); font-size: 12px; font-weight: 780; }

    .top-three { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; margin-bottom: 16px; }
    .priority-card { border-radius: 16px; padding: 15px; }
    .rank { width: 28px; height: 28px; display: grid; place-items: center; border-radius: 9px; background: #111827; color: #fff; font-size: 12px; font-weight: 850; margin-bottom: 10px; }
    html[data-theme="dark"] .rank { background: #f8fafc; color: #111827; }
    .priority-card h3 { margin: 0 0 9px; font-size: 15px; line-height: 1.42; letter-spacing: -0.02em; font-weight: 820; }

    .chip-row,
    .task-meta { display: flex; flex-wrap: wrap; gap: 6px; }
    .chip { display: inline-flex; align-items: center; padding: 5px 8px; border-radius: 999px; font-size: 11px; font-weight: 750; background: var(--surface); color: var(--muted); border: 1px solid var(--line); }
    .chip.danger { background: var(--danger-soft); color: var(--danger); border-color: transparent; }
    .chip.warning { background: var(--warning-soft); color: var(--warning); border-color: transparent; }
    .chip.success { background: var(--success-soft); color: var(--success); border-color: transparent; }
    .chip.primary { background: var(--primary-soft); color: var(--primary); border-color: transparent; }

    .filter-tabs { display: flex; flex-wrap: wrap; gap: 7px; margin-bottom: 11px; }
    .pill-btn,
    .primary-btn,
    .ghost-btn { padding: 9px 11px; font-size: 12px; }
    .pill-btn.active { background: var(--primary-soft); color: var(--primary); border-color: transparent; }
    .primary-btn { border-color: transparent; background: var(--primary); color: #fff; }
    .primary-btn:hover { filter: brightness(0.98); transform: translateY(-1px); box-shadow: var(--shadow); }
    .ghost-btn { background: var(--surface-soft); color: var(--muted); }
    .pill-btn.delete { background: var(--danger-soft); color: var(--danger); border-color: transparent; }

    .toolbar { display: grid; grid-template-columns: minmax(0, 1fr) 145px 155px; gap: 9px; margin-bottom: 13px; }
    .input,
    .select { width: 100%; padding: 11px 12px; border-radius: 12px; border: 1px solid var(--line); background: var(--surface); color: var(--text); outline: none; font-size: 13px; }
    .input:focus,
    .select:focus { border-color: rgba(79, 70, 229, 0.38); box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.07); }

    .task-list { display: grid; gap: 9px; }
    .task-row { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 14px; align-items: center; border-radius: 16px; padding: 14px; }
    .task-row.is-done { opacity: 0.56; }
    .task-title-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
    .task-main h4 { margin: 0; font-size: 15px; letter-spacing: -0.02em; font-weight: 820; }
    .task-main p { margin: 0 0 8px; font-size: 12px; line-height: 1.5; color: var(--muted); }

    .progress-wrap { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 8px; align-items: center; margin-top: 9px; }
    .progress-track { height: 6px; border-radius: 999px; background: rgba(17,24,39,0.06); overflow: hidden; border: 0; }
    html[data-theme="dark"] .progress-track { background: rgba(255,255,255,0.12); }
    .progress-bar { height: 100%; border-radius: inherit; background: var(--primary); opacity: 0.78; }
    .progress-text { font-size: 11.5px; font-weight: 800; color: var(--muted); }
    .task-actions { display: flex; flex-wrap: wrap; gap: 7px; justify-content: flex-end; }

    .right-stack { display: grid; gap: 16px; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 11px; }
    .form-grid .full { grid-column: 1 / -1; }
    .form-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 9px; }
    label { display: grid; gap: 6px; font-size: 11.5px; font-weight: 780; color: var(--muted); }
    .range-value { color: var(--primary); font-weight: 850; }
    input[type="range"] { width: 100%; accent-color: var(--primary); }

    @media (max-width: 1120px) {
      .summary-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .content-grid { grid-template-columns: 1fr; }
      .subject-panel { position: static; max-height: none; }
      .subject-board { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .top-three { grid-template-columns: 1fr; }
    }
    @media (max-width: 860px) {
      .hero { grid-template-columns: 1fr; padding: 24px; }
      .top-controls { width: 100%; }
      .day-nav { width: 100%; grid-template-columns: 1fr auto 1fr; }
      .calendar-grid { gap: 7px; }
      .day-cell { min-height: 102px; }
      .toolbar { grid-template-columns: 1fr; }
      .form-grid { grid-template-columns: 1fr; }
      .form-actions { grid-template-columns: 1fr; }
      .subject-board { grid-template-columns: 1fr; }
      .task-row { grid-template-columns: 1fr; }
      .task-actions { justify-content: flex-start; }
      .focus-block { grid-template-columns: 1fr; }
      .section-header { align-items: flex-start; flex-direction: column; }
    }
  </style>

  <style id="clean-white-refinement">
    :root { --shadow: 0 10px 28px rgba(15, 23, 42, 0.055); --primary-soft: #f0f2ff; }
    body { font-family: Inter, Pretendard, -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans KR", "Apple SD Gothic Neo", sans-serif; letter-spacing: -0.01em; }
    .hero { padding: 24px 26px; background: #ffffff; border: 1px solid #edf0f5; box-shadow: 0 10px 30px rgba(15, 23, 42, 0.045); }
    .app-title { color: #4f46e5; font-size: clamp(30px, 4.5vw, 48px); line-height: 1.08; letter-spacing: -0.035em; font-weight: 650; }
    .subtitle { margin-top: 10px; font-size: 14px; font-weight: 400; color: #697386; max-width: 760px; }
  </style>

  <style id="calm-studio-redesign">
    :root { --bg: #f4f5f7; --surface: #ffffff; --surface-soft: #f8f9fb; --line: #e7e9ee; --text: #202631; --muted: #727b8a; --primary: #4f46e5; --primary-soft: #f0f1ff; --shadow: 0 6px 22px rgba(16, 24, 40, 0.045); }
    body { background: var(--bg); font-weight: 350; }
    .card { border-radius: 20px; background-image: none !important; }
  </style>

  <style id="final-right-form-medium-font">
    body { font-weight: 400 !important; background: #f6f7f9 !important; }
    .app-title { font-weight: 600 !important; letter-spacing: -0.045em !important; color: #2f3542 !important; }
    .content-grid { grid-template-columns: minmax(230px, 0.55fr) minmax(0, 1.45fr) minmax(340px, 0.88fr) !important; align-items: start !important; }
    .right-stack { display: grid !important; gap: 14px !important; position: sticky !important; top: 18px !important; align-self: start !important; }
  </style>

  <style id="subject-background-fix">
    .subject-card[style], .priority-card[style], .task-row[style], .focus-block[style] { background-image: none !important; }
    .progress-bar { background-image: none !important; background-color: #6366f1 !important; }
  </style>

  <style id="softer-pastel-final">
    .subject-card.active { filter: saturate(0.98); box-shadow: inset 0 0 0 1px rgba(79, 70, 229, 0.10), 0 8px 18px rgba(15, 23, 42, 0.035); }
  </style>

  <style id="progress-ring-style">
    .day-progress-ring {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: var(--line-strong); /* 기본 배경색 (데이터 없을 때) */
      display: inline-flex;
      align-items: center;
      justify-content: center;
      position: relative;
      flex-shrink: 0;
    }

    /* 도넛 가운데를 뚫어주는 안쪽 원 */
    .day-progress-inner {
      width: 14px;
      height: 14px;
      background: var(--surface); /* 카드 기본 배경색과 동일하게 */
      border-radius: 50%;
      position: absolute;
      transition: background 0.14s ease;
    }

    /* 다크모드 및 호버 시 안쪽 원 색상 동기화 */
    html[data-theme="dark"] .day-progress-inner { background: var(--surface); }
    .day-cell:hover .day-progress-inner { background: var(--surface-soft); }
    .day-cell.muted:hover .day-progress-inner { background: var(--surface-soft); }
  </style>

</head>
<body>
  <div class="page">
    
    <section class="hero card">
      <div>
        <h1 class="app-title">ADAPTIVE STUDY PLANNER</h1>
        <p class="subtitle" data-i18n="subtitle">학습 계획의 진행률을 직관적으로 확인하고 관리하세요.</p>
      </div>
      <div class="top-controls">
        <div class="mode-controls">
          <button class="toggle-btn" id="themeToggleBtn" type="button">다크 모드</button>
          <button class="toggle-btn" id="languageToggleBtn" type="button">ENG</button>
        </div>
        <div class="day-nav" aria-label="date navigation">
          <button class="day-btn" id="prevDayBtn" type="button" data-i18n="prevDay">어제</button>
          <div class="selected-date" id="selectedDateLabel">2026. 06. 09</div>
          <button class="day-btn" id="nextDayBtn" type="button" data-i18n="nextDay">내일</button>
          <button class="today-nav-btn" id="todayBtn" type="button" data-i18n="goToday">오늘로 이동</button>
        </div>
      </div>
    </section>

    <section class="summary-grid" aria-label="study summary">
      <article class="card metric-card">
        <div class="metric-label"><span data-i18n="completionRate">목표 달성률</span> <span class="dot success"></span></div>
        <div class="metric-value" id="completionRate">75%</div>
        <div class="metric-help" id="completionMessage">아주 잘하고 있어요!</div>
      </article>
      <article class="card metric-card">
        <div class="metric-label">총 학습 시간 <span class="dot primary"></span></div>
        <div class="metric-value">4h 30m</div>
        <div class="metric-help">오늘 누적 시간</div>
      </article>
      <article class="card metric-card">
        <div class="metric-label">남은 계획 <span class="dot warning"></span></div>
        <div class="metric-value">3개</div>
        <div class="metric-help">오늘의 필수 과제</div>
      </article>
      <article class="card metric-card">
        <div class="metric-label">집중도 <span class="dot danger"></span></div>
        <div class="metric-value">High</div>
        <div class="metric-help">방해 요소 적음</div>
      </article>
    </section>

    <section class="card calendar-card">
      <div class="section-header">
        <div>
          <h2 class="section-title">이번 달 일정</h2>
          <p class="section-caption">각 날짜의 원형 그래프로 과목별 달성도를 확인하세요.</p>
        </div>
        <div class="calendar-nav">
          <button class="icon-btn">&lt;</button>
          <div class="month-label">2026년 6월</div>
          <button class="icon-btn">&gt;</button>
        </div>
      </div>

      <div class="calendar-weekdays">
        <div class="weekday">SUN</div><div class="weekday">MON</div><div class="weekday">TUE</div>
        <div class="weekday">WED</div><div class="weekday">THU</div><div class="weekday">FRI</div><div class="weekday">SAT</div>
      </div>
      
      <div class="calendar-grid" id="calendarGrid">
        </div>
    </section>

    <section class="content-grid">
      <aside class="card panel subject-panel">
        <h3 class="section-title" style="margin: 0 0 15px; font-size: 16px;">내 과목/프로젝트</h3>
        <div class="subject-board">
          <div class="subject-card active">
            <div class="subject-head">
              <span class="subject-name">인공지능 개론</span>
              <span class="subject-count">3</span>
            </div>
            <div class="subject-stat">진행률: 60%</div>
          </div>
          <div class="subject-card">
            <div class="subject-head">
              <span class="subject-name">선형대수학</span>
              <span class="subject-count">1</span>
            </div>
            <div class="subject-stat">진행률: 100%</div>
          </div>
        </div>
      </aside>

      <main class="card panel">
        <div class="toolbar">
          <input type="text" class="input" placeholder="계획 검색..." />
          <select class="select">
            <option>우선순위 순</option>
            <option>마감일 순</option>
          </select>
        </div>
        <div class="task-list">
          <div class="task-row">
            <div class="task-main">
              <div class="task-title-row">
                <h4>벡터 공간 복습하기</h4>
                <span class="chip primary">선형대수학</span>
              </div>
              <p>Ch.4 벡터 공간과 부분공간 개념 정리 및 예제 풀이</p>
              <div class="progress-wrap">
                <div class="progress-track"><div class="progress-bar" style="width: 100%;"></div></div>
                <span class="progress-text">100%</span>
              </div>
            </div>
            <div class="task-actions">
              <button class="ghost-btn">수정</button>
            </div>
          </div>
        </div>
      </main>

      <aside class="right-stack">
        <div class="card panel">
          <h3 class="section-title" style="margin: 0 0 15px; font-size: 16px;">새 계획 추가</h3>
          <div class="form-grid">
            <label class="full">계획 이름 <input type="text" class="input" /></label>
            <label>과목 선택
              <select class="select">
                <option>선형대수학</option>
                <option>인공지능 개론</option>
              </select>
            </label>
            <label>예상 시간 (분) <input type="number" class="input" placeholder="60" /></label>
            <div class="form-actions full" style="margin-top: 10px;">
              <button class="ghost-btn">취소</button>
              <button class="primary-btn">추가하기</button>
            </div>
          </div>
        </div>
      </aside>
    </section>

  </div>

  <script>
    // 1. 계획 배열을 받아 도넛 차트용 conic-gradient CSS를 생성하는 함수
    function generateProgressRingCSS(tasks) {
      if (!tasks || tasks.length === 0) {
        return 'var(--line-strong)'; // 계획이 없을 때 회색
      }

      let gradientStops = [];
      let currentPercentage = 0;

      tasks.forEach(task => {
        if (task.progress > 0) {
          let start = currentPercentage;
          let end = currentPercentage + task.progress;
          gradientStops.push(`${task.color} ${start}% ${end}%`);
          currentPercentage = end;
        }
      });

      // 진행률 총합이 100% 미만이면 나머지는 빈 공간(회색 선)으로 채움
      if (currentPercentage < 100) {
        gradientStops.push(`var(--line-strong) ${currentPercentage}% 100%`);
      }

      return `conic-gradient(${gradientStops.join(', ')})`;
    }

    // 2. 임의의 6월 달력 데이터 생성 및 렌더링
    const calendarGrid = document.getElementById('calendarGrid');
    
    // 임의의 과목 색상 변수 매핑
    const colors = {
      ai: '#4f46e5',    // 인공지능 (Primary)
      math: '#2f855a',  // 선형대수학 (Success)
      os: '#b7791f'     // 운영체제 (Warning)
    };

    // 6월 1일부터 30일까지 그리기 (1일은 월요일이라 가정)
    for (let i = 1; i <= 35; i++) { // 35칸 (5주)
      const dayCell = document.createElement('div');
      
      if (i > 30) {
        // 다음 달 날짜 (음영 처리)
        dayCell.className = 'day-cell muted';
        dayCell.innerHTML = `<div class="day-number"><span>${i - 30}</span></div>`;
      } else {
        // 이번 달 날짜
        dayCell.className = 'day-cell' + (i === 9 ? ' today' : ''); // 9일을 오늘로 가정

        // 각 날짜별 임의의 진행률 데이터 생성 (예시)
        let dayTasks = [];
        if (i % 3 === 0) dayTasks.push({ color: colors.ai, progress: 40 });
        if (i % 4 === 0) dayTasks.push({ color: colors.math, progress: 30 });
        if (i === 9) dayTasks = [
          { color: colors.ai, progress: 30 },
          { color: colors.math, progress: 45 }
        ]; // 오늘(9일)은 두 과목 합쳐 75% 진행
        
        // 프로그래스 링 CSS 생성
        const ringBg = generateProgressRingCSS(dayTasks);

        // 셀 내부 HTML 조합
        dayCell.innerHTML = `
          <div class="day-number">
            <span>${i}</span>
            <div class="day-progress-ring" style="background: ${ringBg};">
              <div class="day-progress-inner"></div>
            </div>
          </div>
          <div class="badge-stack">
            ${dayTasks.length > 0 ? `<span class="mini-badge gray">${dayTasks.length} Plans</span>` : ''}
          </div>
        `;
      }
      calendarGrid.appendChild(dayCell);
    }

    // 3. 다크모드 토글 버튼 로직
    const themeToggleBtn = document.getElementById('themeToggleBtn');
    themeToggleBtn.addEventListener('click', () => {
      const html = document.documentElement;
      if (html.getAttribute('data-theme') === 'light') {
        html.setAttribute('data-theme', 'dark');
        themeToggleBtn.textContent = '라이트 모드';
      } else {
        html.setAttribute('data-theme', 'light');
        themeToggleBtn.textContent = '다크 모드';
      }
    });
  </script>
</body>
</html>
